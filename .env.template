# -------------------------
# Runtime Configuration
# -------------------------
# 服务器监听端口（Node 模式）
PORT=8787
# Root 用户的鉴权 Token，用于管理员接口访问
ROOT_TOKEN=root-token-123
# 业务数据库文件路径（Node 模式），默认为项目根目录的 local.db
DB_PATH=./local.db
# 是否在 recordService 中打印请求记录创建/更新日志，适合本地排查
RECORD_LOG_ENABLED=false
# 是否将流式响应原始 SSE 内容写入 log/stream/<record.id>.log（仅本地 Node 模式生效）
STREAM_LOG_ENABLED=false

# -------------------------
# Test Server Configuration
# -------------------------
# Node 模式下测试服务器的访问地址（仅 TEST_MODE=node 时使用）
TEST_BASE_URL=http://localhost:3000
# Node 模式下测试服务器监听端口
TEST_PORT=3000

# -------------------------
# Test Database Configuration
# -------------------------
# 测试数据库文件路径
TEST_DB_PATH=./test.db
# 测试数据库驱动模式，固定为 local（使用 better-sqlite3）
TEST_DB_MODE=local

# -------------------------
# Test Upstream Configuration
# -------------------------
# 以下 OpenAI / Anthropic 配置在 TEST_REAL_API=true 时生效，用于对接真实上游接口
# （若存在 resource/test_real_config.json，则优先读取该文件中的配置）
# 真实 OpenAI 接口地址
TEST_UPSTREAM_OPENAI_URL=https://api.openai.com/v1/chat/completions
# 真实 OpenAI API Key
TEST_UPSTREAM_OPENAI_API_KEY=
# 真实 OpenAI 测试使用的模型
TEST_UPSTREAM_OPENAI_MODEL=gpt-3.5-turbo

# 真实 Anthropic 接口地址
TEST_UPSTREAM_ANTHROPIC_URL=https://api.anthropic.com/v1/messages
# 真实 Anthropic API Key
TEST_UPSTREAM_ANTHROPIC_API_KEY=
# 真实 Anthropic 测试使用的模型
TEST_UPSTREAM_ANTHROPIC_MODEL=claude-3-haiku-20240307

# Mock 服务器地址，模拟 OpenAI / Anthropic 接口（TEST_REAL_API=false 时使用）
TEST_UPSTREAM_MOCK_URL=http://localhost:9999

# -------------------------
# Test Options
# -------------------------
# 测试结束后是否自动清理数据库（设为 false 可保留数据用于排查）
TEST_CLEANUP=true
# 单个测试用例的超时时间（毫秒）
TEST_TIMEOUT=30000
# 是否输出详细的测试过程日志
TEST_VERBOSE=false
