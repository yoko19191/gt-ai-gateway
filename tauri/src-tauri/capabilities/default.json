{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Default capabilities for AI Gateway",
    "windows": ["main", "splashscreen"],
    "permissions": [
        "core:default",
        "core:tray:default",
        "dialog:allow-save",
        "fs:allow-write-text-file",
        "shell:allow-execute",
        "shell:allow-spawn",
        "shell:allow-open"
    ]
}
